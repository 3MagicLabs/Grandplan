.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.json

# --- local models / vault / data (never commit personal data or large models) ---
*.gguf
models/
vault/
*.sqlite
*.db

